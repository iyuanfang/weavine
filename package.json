{
  "name": "prm",
  "version": "0.1.0",
  "description": "PRM · Personal Relationship Manager — 人脉管理桌面应用",
  "author": "iyuanfang",
  "private": true,
  "scripts": {
    "predev": "rm -rf .next",
    "dev": "next dev -p 3100",
    "build": "next build",
    "start": "next start -p 3100",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma db push --force-reset",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "IS_DESKTOP=true next build && DATABASE_URL=\"file:./dev.db\" npx prisma db push && cp prisma/dev.db dev.db && node scripts/copy-tauri-standalone.mjs && node scripts/copy-vc-runtime.mjs && tauri build"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@fullcalendar/core": "6.1.15",
    "@fullcalendar/daygrid": "6.1.15",
    "@fullcalendar/interaction": "6.1.15",
    "@fullcalendar/list": "6.1.15",
    "@fullcalendar/react": "6.1.15",
    "@fullcalendar/timegrid": "6.1.15",
    "@prisma/client": "5.18.0",
    "@tanstack/react-query": "5.59.0",
    "bcryptjs": "^3.0.3",
    "chrono-node": "2.7.7",
    "cmdk": "^1.1.1",
    "next": "14.2.5",
    "next-auth": "5.0.0-beta.31",
    "node-cron": "3.0.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "web-push": "3.6.7",
    "zod": "3.23.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "prisma",
      "@prisma/client",
      "@prisma/engines",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@playwright/test": "1.46.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "20.14.10",
    "@types/node-cron": "3.0.11",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@types/web-push": "3.6.3",
    "autoprefixer": "10.4.19",
    "@tauri-apps/cli": "^2",
    "@tauri-apps/api": "^2",
    "postcss": "8.4.40",
    "prisma": "5.18.0",
    "tailwindcss": "3.4.7",
    "tsx": "4.16.2",
    "typescript": "5.5.3",
    "vitest": "2.0.5"
  }
}
