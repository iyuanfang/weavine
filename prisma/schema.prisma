generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Contact {
  id              String   @id @default(cuid())
  name            String
  company         String?
  title           String?
  city            String?
  email           String?
  phone           String?
  wechat          String?
  birthdayMonth   Int?
  birthdayDay     Int?
  notes           String?
  lastContactedAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tags         ContactTag[]
  events       EventAttendee[]
  interactions Interaction[]
  reminders    Reminder[] @relation("ContactReminders")
  actionsFor   Action[]  @relation("ActionForContact")
  waitingOn    Action[]  @relation("ActionWaitingOn")

  @@index([name])
  @@index([company])
  @@index([city])
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String?
  createdAt DateTime @default(now())

  contacts ContactTag[]
}

model ContactTag {
  contactId String
  tagId     String

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@index([tagId])
}

model Event {
  id        String   @id @default(cuid())
  title     String
  type      String   @default("meeting")
  startAt   DateTime
  endAt     DateTime?
  location  String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attendees EventAttendee[]
  reminders Reminder[]
  actions   Action[] @relation("ActionForEvent")

  @@index([startAt])
}

model Interaction {
  id         String   @id @default(cuid())
  contactId  String
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  occurredAt DateTime
  channel    String?
  summary    String
  createdAt  DateTime @default(now())

  @@index([contactId, occurredAt])
}
model Action {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("inbox") // inbox|open|waiting|done|dropped
  priority    Int      @default(0)
  category    String?
  dueAt       DateTime?
  contactId   String?
  contact     Contact? @relation("ActionForContact", fields: [contactId], references: [id], onDelete: SetNull)
  waitingOnId String?
  waitingOn   Contact? @relation("ActionWaitingOn", fields: [waitingOnId], references: [id], onDelete: SetNull)
  eventId     String?
  event       Event?   @relation("ActionForEvent", fields: [eventId], references: [id], onDelete: SetNull)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, dueAt])
  @@index([contactId])
  @@index([waitingOnId])
  @@index([eventId])
}

model EventAttendee {
  eventId   String
  contactId String

  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([eventId, contactId])
  @@index([contactId])
}

model Reminder {
  id         String   @id @default(cuid())
  contactId  String?
  contact    Contact? @relation("ContactReminders", fields: [contactId], references: [id], onDelete: Cascade)
  eventId    String?
  event      Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  triggerAt  DateTime
  kind       String   @default("event")
  dispatched Boolean  @default(false)
  dismissed  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([triggerAt, dispatched, dismissed])
  @@index([contactId])
}

