generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ────────────────────────────────────────────────────────────
// Auth.js v5 (Prisma adapter) — required schema
// https://authjs.dev/getting-started/adapters/prisma
// ────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  // WeChat identity (reserved, not used yet)
  wechatUnionId String? @unique
  openidWeb     String? @unique
  openidMini    String? @unique

  // Credentials auth
  passwordHash  String?

  // Local-user migration safety net
  isLocal       Boolean   @default(false)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]

  contacts      Contact[]
  events        Event[]
  interactions  Interaction[]
  actions       Action[]
  reminders     Reminder[]
  tags          Tag[]
  contactTags   ContactTag[]
  pushSubscriptions PushSubscription[]
  settings      Setting[]

  @@index([wechatUnionId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ────────────────────────────────────────────────────────────
// Domain — all per-owner
// ────────────────────────────────────────────────────────────

model Contact {
  id              String   @id @default(cuid())
  ownerId         String
  owner           User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  // Nickname (how the user calls them — required).
  nickname        String
  // Real name (optional — many contacts you only know by nickname).
  name            String?
  company         String?
  title           String?
  city            String?
  email           String?
  phone           String?
  wechat          String?
  notes           String?
  importance      String   @default("normal")
  reminderEnabled Boolean  @default(true)
  reminderIntervalDays Int?
  lastContactedAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tags         ContactTag[]
  events       Event[]      @relation("EventContact")
  interactions Interaction[]
  reminders    Reminder[]     @relation("ContactReminders")
  actionsFor   Action[]       @relation("ActionForContact")

  @@index([ownerId, nickname])
  @@index([ownerId, name])
  @@index([ownerId, company])
  @@index([ownerId, city])
  @@index([ownerId, importance])
  @@index([ownerId, reminderEnabled, lastContactedAt])
  @@index([ownerId, lastContactedAt, updatedAt])
  @@unique([ownerId, email])
}

model Tag {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name      String
  color     String?
  createdAt DateTime @default(now())

  contacts  ContactTag[]

  @@unique([ownerId, name])
}

model ContactTag {
  ownerId   String
  contactId String
  tagId     String

  owner   User    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@index([ownerId])
  @@index([tagId])
}

model Event {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title     String
  type      String   @default("会面")
  startAt   DateTime
  endAt     DateTime?
  location  String?
  notes     String?
  contactId String?
  contact   Contact? @relation("EventContact", fields: [contactId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reminders    Reminder[]
  actions      Action[]         @relation("ActionForEvent")
  interactions Interaction[]    @relation("InteractionFromEvent")

  @@index([ownerId, startAt])
  @@index([ownerId, contactId])
}

model Interaction {
  id         String   @id @default(cuid())
  ownerId    String
  owner      User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  contactId  String?
  contact    Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)
  actionId   String?
  action     Action?  @relation("InteractionFromAction", fields: [actionId], references: [id], onDelete: SetNull)
  eventId    String?
  event      Event?   @relation("InteractionFromEvent", fields: [eventId], references: [id], onDelete: SetNull)
  occurredAt DateTime
  channel    String?
  summary    String
  createdAt  DateTime @default(now())

  @@index([ownerId, contactId, occurredAt])
  @@index([ownerId, occurredAt])
}

model Action {
  id          String   @id @default(cuid())
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      String   @default("inbox")
  priority    Int      @default(0)
  category    String?
  dueAt       DateTime?
  contactId   String?
  contact     Contact? @relation("ActionForContact", fields: [contactId], references: [id], onDelete: SetNull)
  eventId     String?
  event       Event?   @relation("ActionForEvent", fields: [eventId], references: [id], onDelete: SetNull)
  completedAt   DateTime?
  interactions  Interaction[] @relation("InteractionFromAction")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ownerId, status, dueAt])
  @@index([ownerId, contactId])
  @@index([ownerId, eventId])
}

model Reminder {
  id         String   @id @default(cuid())
  ownerId    String
  owner      User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  contactId  String?
  contact    Contact? @relation("ContactReminders", fields: [contactId], references: [id], onDelete: Cascade)
  eventId    String?
  event      Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  triggerAt  DateTime
  kind       String   @default("event")
  dispatched Boolean  @default(false)
  dismissed  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([ownerId, triggerAt, dispatched, dismissed])
  @@index([ownerId, contactId])
  @@index([ownerId, contactId, kind, triggerAt])
}

// Per-user settings (replaces prisma/settings.json file)
model Setting {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  key       String
  value     String
  updatedAt DateTime @updatedAt

  @@unique([ownerId, key])
}

// Web Push subscription, per user
model PushSubscription {
  id         String   @id @default(cuid())
  ownerId    String
  owner      User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  endpoint   String   @unique
  p256dh     String
  auth       String
  createdAt  DateTime @default(now())

  @@index([ownerId])
}
