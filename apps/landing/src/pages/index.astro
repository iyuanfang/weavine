---
import '../styles/global.css';

const release = 'v0.2.27';
const repo = 'iyuanfang/weavine';
const releaseUrl = `https://github.com/${repo}/releases/tag/${release}`;

const platforms = [
  { name: 'macOS',     href: `#download-macos`,   file: '.dmg' },
  { name: 'Windows',   href: `#download-windows`, file: '.msi' },
  { name: 'Linux',     href: `#download-linux`,   file: '.deb' },
  { name: 'Android',   href: `#download-android`, file: '.apk' },
  { name: '网页版',     href: '/login',            file: '免安装', primary: true },
];

const features = [
  {
    icon: '🔒',
    title: '本地优先',
    body: '数据存放在你自己的设备上。默认离线可用，隐私和性能都是第一公民。',
  },
  {
    icon: '🔄',
    title: '多端同步',
    body: '桌面、手机、网页，编辑后即时同步。自建服务或官方云，二选一。',
  },
  {
    icon: '💚',
    title: '永久开源',
    body: 'AGPL-3.0 许可。代码可读、协议开放，不会有一天突然停服、收费、改协议。',
  },
];

const downloads = [
  {
    id: 'download-macos',
    name: 'macOS',
    desc: 'Universal · 适用于 Apple Silicon 和 Intel',
    href: releaseUrl,
    file: '.dmg',
  },
  {
    id: 'download-windows',
    name: 'Windows',
    desc: 'Windows 10 / 11 · 64-bit',
    href: releaseUrl,
    file: '.msi',
  },
  {
    id: 'download-linux',
    name: 'Linux',
    desc: 'Debian / Ubuntu · 其他发行版可选 .AppImage',
    href: releaseUrl,
    file: '.deb',
  },
  {
    id: 'download-android',
    name: 'Android',
    desc: 'Android 8+ · 通用 APK，启用"未知来源"安装',
    href: releaseUrl,
    file: '.apk',
  },
  {
    name: '网页版',
    desc: '无需安装，浏览器即开即用',
    href: '/login',
    file: '→',
  },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Weavine — 本地优先的个人关系管理工具。数据存放在你自己的设备上，多端同步，永久开源。" />
    <meta name="theme-color" content="#7c3aed" />
    <title>Weavine · 本地优先的个人关系管理</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="font-sans">
    <header class="border-b border-gray-100 sticky top-0 bg-white/80 backdrop-blur z-10">
      <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="font-semibold text-lg tracking-tight">Weavine</a>
        <nav class="flex gap-6 text-sm text-gray-600">
          <a href="#features" class="hover:text-gray-900 transition">特性</a>
          <a href="#download" class="hover:text-gray-900 transition">下载</a>
          <a href={`https://github.com/${repo}`} class="hover:text-gray-900 transition" rel="noopener">GitHub</a>
        </nav>
      </div>
    </header>

    <main>
      <!-- Hero -->
      <section class="max-w-5xl mx-auto px-6 py-20 sm:py-28 text-center">
        <h1 class="text-4xl sm:text-6xl font-bold tracking-tight">本地优先的个人关系管理</h1>
        <p class="mt-6 text-lg sm:text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed">
          Weavine 帮你记住每一个重要的人、每一件待办的事。
          数据存放在你自己的设备上，多端加密同步，永久开源。
        </p>
        <div class="mt-10 flex flex-wrap gap-3 justify-center">
          {platforms.map((p) => (
            <a
              href={p.href}
              class:list={[
                'inline-flex items-center gap-1.5 px-5 py-2.5 rounded-lg font-medium transition',
                p.primary
                  ? 'bg-brand-600 text-white hover:bg-brand-700'
                  : 'bg-gray-100 text-gray-900 hover:bg-gray-200',
              ]}
            >
              <span>{p.name}</span>
              <span class="text-xs opacity-70">{p.file}</span>
            </a>
          ))}
        </div>
        <p class="mt-6 text-sm text-gray-500">
          最新版本 <a href={`https://github.com/${repo}/releases/tag/${release}`} class="underline hover:text-gray-700" rel="noopener">{release}</a>
          · AGPL-3.0
        </p>
      </section>

      <!-- Features -->
      <section id="features" class="bg-gray-50 py-20">
        <div class="max-w-5xl mx-auto px-6">
          <h2 class="text-3xl font-bold text-center">为什么用 Weavine</h2>
          <div class="mt-12 grid sm:grid-cols-3 gap-8">
            {features.map((f) => (
              <div>
                <div class="w-10 h-10 rounded-lg bg-brand-100 text-brand-600 flex items-center justify-center text-xl">{f.icon}</div>
                <h3 class="mt-4 text-lg font-semibold">{f.title}</h3>
                <p class="mt-2 text-gray-600 text-sm leading-relaxed">{f.body}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Screenshots -->
      <section class="py-20">
        <div class="max-w-5xl mx-auto px-6">
          <h2 class="text-3xl font-bold text-center">看看实际效果</h2>
          <p class="mt-4 text-center text-gray-500 text-sm">截图待补 · 跑起来后加 3 张</p>
          <div class="mt-12 grid sm:grid-cols-3 gap-6">
            <div class="aspect-[4/3] bg-gray-100 rounded-lg flex items-center justify-center text-gray-400 text-sm">主页</div>
            <div class="aspect-[4/3] bg-gray-100 rounded-lg flex items-center justify-center text-gray-400 text-sm">联系人详情</div>
            <div class="aspect-[4/3] bg-gray-100 rounded-lg flex items-center justify-center text-gray-400 text-sm">Android</div>
          </div>
        </div>
      </section>

      <!-- Download -->
      <section id="download" class="bg-gray-50 py-20">
        <div class="max-w-5xl mx-auto px-6">
          <h2 class="text-3xl font-bold text-center">下载</h2>
          <p class="mt-4 text-center text-gray-600 text-sm">所有版本发布在 GitHub Releases，永久保留</p>
          <div class="mt-12 max-w-2xl mx-auto divide-y divide-gray-200 bg-white rounded-lg border border-gray-200">
            {downloads.map((d) => (
              <a
                id={d.id}
                href={d.href}
                class="flex items-center justify-between p-5 hover:bg-gray-50 transition"
                rel={d.href.startsWith('http') ? 'noopener' : undefined}
              >
                <div>
                  <div class="font-medium">{d.name}</div>
                  <div class="text-sm text-gray-500 mt-0.5">{d.desc}</div>
                </div>
                <span class="text-gray-400 text-sm">{d.file}</span>
              </a>
            ))}
          </div>
          <p class="mt-6 text-center text-sm text-gray-500">
            找不到适合你系统的版本？去
            <a href={`https://github.com/${repo}/releases`} class="underline hover:text-gray-700" rel="noopener">Releases 页面</a>
            查看全部历史版本。
          </p>
        </div>
      </section>

      <!-- Open source -->
      <section class="py-20">
        <div class="max-w-3xl mx-auto px-6 text-center">
          <h2 class="text-3xl font-bold">永远开源</h2>
          <p class="mt-4 text-gray-600 leading-relaxed">
            Weavine 以 AGPL-3.0 协议开源。
            任何人都可以查看、修改、部署自己的副本。
            不会有一天突然收费、停服、改协议。
          </p>
          <a
            href={`https://github.com/${repo}`}
            class="mt-8 inline-flex items-center px-5 py-2.5 rounded-lg font-medium bg-gray-900 text-white hover:bg-gray-800 transition"
            rel="noopener"
          >
            查看 GitHub 仓库 →
          </a>
        </div>
      </section>
    </main>

    <footer class="border-t border-gray-100 py-8">
      <div class="max-w-5xl mx-auto px-6 text-sm text-gray-500 flex flex-col sm:flex-row gap-2 justify-between">
        <div>© 2026 Weavine · AGPL-3.0</div>
        <div class="flex gap-4">
          <a href={`https://github.com/${repo}`} class="hover:text-gray-900" rel="noopener">GitHub</a>
          <a href={`https://github.com/${repo}/releases`} class="hover:text-gray-900" rel="noopener">Releases</a>
          <a href={`https://github.com/${repo}/blob/main/LICENSE`} class="hover:text-gray-900" rel="noopener">License</a>
        </div>
      </div>
    </footer>
  </body>
</html>
