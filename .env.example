# Desktop (SQLite) — runtime DB location used by `weavine` (Tauri) and `weavine-web` (browser).
DATABASE_URL="file:./dev.db"

# Sync server (PostgreSQL) — uncomment when running sync
# DATABASE_URL="postgresql://user:password@127.0.0.1:5432/prm"

# HTTP base URL the web-spa talks to when running outside Tauri.
# In Tauri webview, TauriAdapter calls Rust commands via invoke() and
# ignores this. In browser, web-spa uses VITE_API_BASE; copy the same
# value into apps/web-spa/.env.local during dev if you need a custom port.
VITE_API_BASE="http://localhost:3000"
