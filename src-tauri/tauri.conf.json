{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Weavine",
  "version": "0.1.0",
  "identifier": "com.weavine.prm",
  "build": {
    "frontendDist": "../tauri-dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Weavine",
        "url": "/",
        "width": 1280,
        "height": 820
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "msi"],
    "resources": ["../standalone-bundle/**/*", "../node_bin/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
