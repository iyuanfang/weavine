{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Weavine",
  "version": "0.1.0",
  "identifier": "com.weavine.prm",
  "build": {
    "frontendDist": "../tauri-dist",
    "devUrl": "http://localhost:5181"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Weavine",
        "url": "http://localhost:5181",
        "width": 1280,
        "height": 820,
        "visible": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "msi"],
    "resources": [
      "../dev.db",
      "../standalone-bundle/dev.db",
      "../standalone-bundle/**/*",
      "../node_bin/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      }
    }
  }
}
