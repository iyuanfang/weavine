{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Weavine",
  "version": "0.1.0",
  "identifier": "com.weavine.app",
  "build": {
    "frontendDist": "../.next/standalone"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Weavine",
        "width": 1280,
        "height": 820
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
