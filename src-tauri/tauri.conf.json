{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Weavine",
  "version": "0.1.0",
  "identifier": "com.weavine.prm",
  "build": {
    "frontendDist": "../tauri-dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Weavine",
        "url": "/",
        "width": 1280,
        "height": 820,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "msi"],
    "resources": {
      "../standalone-bundle/**/*": "./",
      "../standalone-bundle/dev.db": "./dev.db",
      "../node_bin/*": "node_bin/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      }
    }
  }
}
