{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Weavine",
  "version": "0.1.0",
  "identifier": "com.weavine.app",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3100",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "IS_DESKTOP=true pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "PRM · 人脉管理",
        "width": 1280,
        "height": 820,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
